---
import { channelConfig } from '../config/channel';

interface Props {
  variant?: 'home' | 'trigger';
  class?: string;
}

const { variant = 'trigger', class: className = '' } = Astro.props;

const baseClass =
  'channel-avatar w-10 h-10 rounded-full flex-shrink-0 object-cover transition-transform duration-200';
const interactiveClass =
  variant === 'home'
    ? 'channel-avatar--home cursor-pointer hover:scale-105 active:scale-95'
    : 'channel-avatar--trigger cursor-pointer hover:scale-110 active:scale-95';
---

{
  variant === 'home' ? (
    <a href={import.meta.env.BASE_URL} class="inline-flex flex-shrink-0 rounded-full" aria-label="返回首页">
      <img
        src={channelConfig.avatarUrl}
        alt={channelConfig.name}
        class:list={[baseClass, interactiveClass, className]}
      />
    </a>
  ) : (
    <button
      type="button"
      class="inline-flex flex-shrink-0 rounded-full border-none bg-transparent p-0"
      data-lulu-trigger
      aria-label={`查看${channelConfig.name}卡片`}
    >
      <img
        src={channelConfig.avatarUrl}
        alt={channelConfig.name}
        class:list={[baseClass, interactiveClass, className]}
      />
    </button>
  )
}
