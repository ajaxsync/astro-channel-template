---
import { channelConfig } from '../config/channel';
import { luluQuotes } from '../config/lulu-quotes';

const quotesJson = JSON.stringify(luluQuotes);
---

<div
  id="lulu-modal"
  class="lulu-modal"
  hidden
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="lulu-modal-name"
>
  <div class="lulu-modal__backdrop" data-lulu-close></div>

  <div class="lulu-modal__stage">
    <div class="lulu-modal__card" id="lulu-modal-card">
      <div class="lulu-modal__card-flip" id="lulu-modal-card-flip">
        <div class="lulu-modal__face lulu-modal__face--back" aria-hidden="true"></div>
        <div class="lulu-modal__face lulu-modal__face--front">
          <div class="lulu-modal__avatar-ring">
            <img
              src={channelConfig.avatarUrl}
              alt=""
              class="lulu-modal__avatar"
              width="80"
              height="80"
            />
          </div>
          <h2 id="lulu-modal-name" class="lulu-modal__name">{channelConfig.name}</h2>
          <div class="lulu-modal__divider"></div>
          <p class="lulu-modal__quote" id="lulu-modal-quote"></p>
          <button type="button" class="lulu-modal__redraw" id="lulu-modal-redraw">
            再抽一张
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ quotesJson }}>
  const quotes = JSON.parse(quotesJson);

  function initLuluModal() {
    const modal = document.getElementById('lulu-modal');
    const quoteEl = document.getElementById('lulu-modal-quote');
    const backdrop = modal?.querySelector('[data-lulu-close]');
    const cardFlip = document.getElementById('lulu-modal-card-flip');
    const card = document.getElementById('lulu-modal-card');
    const redrawBtn = document.getElementById('lulu-modal-redraw');

    if (!modal || !quoteEl || !backdrop || !cardFlip || !card || !redrawBtn) return;
    if (modal.dataset.luluBound === 'true') return;
    modal.dataset.luluBound = 'true';

    let isOpen = false;
    let lastQuote = '';
    let tapTimer = 0;
    let closeTimer = 0;

    const pickQuote = () => {
      if (quotes.length <= 1) return quotes[0];
      let next = quotes[Math.floor(Math.random() * quotes.length)];
      while (next === lastQuote) {
        next = quotes[Math.floor(Math.random() * quotes.length)];
      }
      lastQuote = next;
      return next;
    };

    const replayQuoteAnimation = () => {
      quoteEl.style.animation = 'none';
      void quoteEl.offsetHeight;
      quoteEl.style.animation = '';
    };

    const resetCardState = () => {
      cardFlip.classList.remove('is-entering', 'is-closing', 'is-redrawing', 'is-settled');
      card.classList.remove('is-tapped');
    };

    const finishClose = () => {
      clearTimeout(closeTimer);
      isOpen = false;
      modal.classList.remove('is-visible');
      modal.setAttribute('hidden', '');
      modal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('lulu-modal-open');
      resetCardState();
    };

    const openModal = () => {
      if (isOpen) return;
      isOpen = true;

      quoteEl.textContent = pickQuote();
      replayQuoteAnimation();

      modal.removeAttribute('hidden');
      modal.setAttribute('aria-hidden', 'false');
      document.body.classList.add('lulu-modal-open');

      requestAnimationFrame(() => {
        modal.classList.add('is-visible');
        resetCardState();
        void cardFlip.offsetWidth;
        cardFlip.classList.add('is-entering');
      });
    };

    const closeModal = () => {
      if (!isOpen) return;

      modal.classList.remove('is-visible');
      cardFlip.classList.remove('is-entering', 'is-redrawing', 'is-settled');
      cardFlip.classList.add('is-closing');

      clearTimeout(closeTimer);
      closeTimer = window.setTimeout(finishClose, 350);

      const onEnd = (e) => {
        if (e.target !== cardFlip) return;
        cardFlip.removeEventListener('animationend', onEnd);
        finishClose();
      };
      cardFlip.addEventListener('animationend', onEnd);
    };

    const playCardTap = (e) => {
      if (!isOpen || cardFlip.classList.contains('is-redrawing')) return;
      if (e.target === redrawBtn || redrawBtn.contains(e.target)) return;

      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;

      card.style.setProperty('--tap-x', String(x));
      card.style.setProperty('--tap-y', String(y));

      card.classList.remove('is-tapped');
      void card.offsetWidth;
      card.classList.add('is-tapped');

      clearTimeout(tapTimer);
      tapTimer = window.setTimeout(() => card.classList.remove('is-tapped'), 800);
    };

    const redrawQuote = () => {
      if (!isOpen || cardFlip.classList.contains('is-redrawing')) return;

      cardFlip.classList.remove('is-settled', 'is-redrawing');
      void cardFlip.offsetWidth;
      cardFlip.classList.add('is-redrawing');

      window.setTimeout(() => {
        quoteEl.textContent = pickQuote();
      }, 450);

      const onEnd = (e) => {
        if (e.target !== cardFlip || e.animationName !== 'lulu-card-flip') return;
        cardFlip.removeEventListener('animationend', onEnd);
        cardFlip.classList.remove('is-redrawing');
        cardFlip.classList.add('is-settled');
      };
      cardFlip.addEventListener('animationend', onEnd);
    };

    cardFlip.addEventListener('animationend', (e) => {
      if (e.target !== cardFlip || e.animationName !== 'lulu-card-enter') return;
      cardFlip.classList.remove('is-entering');
      cardFlip.classList.add('is-settled');
    });

    document.querySelectorAll('[data-lulu-trigger]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        openModal();
      });
    });

    backdrop.addEventListener('click', closeModal);
    card.addEventListener('click', playCardTap);
    redrawBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      redrawQuote();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeModal();
    });
  }

  initLuluModal();
  document.addEventListener('astro:page-load', initLuluModal);
</script>

<style is:global>
  body.lulu-modal-open {
    overflow: hidden;
  }

  .lulu-modal[hidden] {
    display: none !important;
  }

  .lulu-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    visibility: hidden;
  }

  .lulu-modal.is-visible {
    pointer-events: auto;
    visibility: visible;
  }

  .lulu-modal__backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, #000 45%, transparent);
    opacity: 0;
    backdrop-filter: blur(0);
    -webkit-backdrop-filter: blur(0);
    transition:
      opacity 0.35s ease,
      backdrop-filter 0.35s ease,
      -webkit-backdrop-filter 0.35s ease;
    cursor: pointer;
  }

  .lulu-modal.is-visible .lulu-modal__backdrop {
    opacity: 1;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .lulu-modal__stage {
    position: relative;
    perspective: 900px;
    z-index: 1;
  }

  .lulu-modal__card {
    position: relative;
    width: min(300px, calc(100vw - 3rem));
    transform-style: preserve-3d;
    cursor: pointer;
    --tap-x: 0;
    --tap-y: 0;
  }

  .lulu-modal__card.is-tapped {
    animation: lulu-card-tap 0.75s cubic-bezier(0.34, 1.2, 0.64, 1);
  }

  .lulu-modal__card-flip {
    position: relative;
    width: 100%;
    transform-style: preserve-3d;
    transform: scale(1) rotateY(0deg);
    opacity: 0;
  }

  .lulu-modal.is-visible .lulu-modal__card-flip.is-settled,
  .lulu-modal.is-visible .lulu-modal__card-flip.is-redrawing {
    opacity: 1;
  }

  .lulu-modal__card-flip.is-entering {
    animation: lulu-card-enter 0.45s cubic-bezier(0.34, 1.4, 0.64, 1) forwards;
  }

  .lulu-modal__card-flip.is-closing {
    animation: lulu-card-exit 0.3s cubic-bezier(0.55, 0, 1, 0.45) forwards;
  }

  .lulu-modal__card-flip.is-redrawing {
    opacity: 1;
    animation: lulu-card-flip 0.9s cubic-bezier(0.45, 0.05, 0.25, 1) forwards;
  }

  .lulu-modal__card-flip.is-settled {
    transform: scale(1) rotateY(0deg);
    opacity: 1;
  }

  .lulu-modal__face {
    width: 100%;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 1rem;
  }

  .lulu-modal__face--front {
    position: relative;
    transform: rotateY(0deg);
    padding: 1.75rem 1.5rem 1.25rem;
    text-align: center;
    background: color-mix(in srgb, var(--tg-bubble) 92%, transparent);
    border: 1px solid color-mix(in srgb, var(--tg-accent) 30%, var(--tg-border));
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    overflow: hidden;
    box-shadow:
      0 16px 40px color-mix(in srgb, #000 22%, transparent),
      0 0 0 1px color-mix(in srgb, #ffd700 20%, transparent);
  }

  /* 卡片边缘自发光 */
  .lulu-modal__face--front::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    padding: 1px;
    background: conic-gradient(
      from var(--lulu-glow-angle, 0deg),
      transparent 0%,
      color-mix(in srgb, #ffd700 80%, var(--tg-accent)) 12%,
      transparent 24%,
      color-mix(in srgb, var(--tg-accent) 70%, #fff) 38%,
      transparent 50%,
      color-mix(in srgb, #ffd700 60%, var(--tg-accent)) 62%,
      transparent 74%,
      color-mix(in srgb, var(--tg-accent) 50%, #ffd700) 88%,
      transparent 100%
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask-composite: exclude;
    opacity: 0;
    animation: lulu-edge-glow 3s ease-in-out infinite;
    pointer-events: none;
  }

  .lulu-modal.is-visible .lulu-modal__face--front::before {
    opacity: 1;
  }

  .lulu-modal:not(.is-visible) .lulu-modal__face--front::before,
  .lulu-modal:not(.is-visible) .lulu-modal__face--front::after {
    animation: none;
    opacity: 0;
  }

  .lulu-modal__face--front::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    box-shadow:
      inset 0 0 24px color-mix(in srgb, var(--tg-accent) 8%, transparent),
      inset 0 0 48px color-mix(in srgb, #ffd700 6%, transparent);
    pointer-events: none;
    animation: lulu-inner-glow 2.5s ease-in-out infinite alternate;
  }

  .lulu-modal__face--back {
    position: absolute;
    inset: 0;
    min-height: 100%;
    transform: rotateY(180deg);
    background: color-mix(in srgb, var(--tg-bubble) 92%, transparent);
    border: 1px solid color-mix(in srgb, var(--tg-accent) 20%, var(--tg-border));
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    box-shadow:
      0 16px 40px color-mix(in srgb, #000 18%, transparent),
      inset 0 0 32px color-mix(in srgb, var(--tg-accent) 5%, transparent);
  }

  .lulu-modal__avatar-ring {
    position: relative;
    z-index: 1;
    display: inline-flex;
    padding: 3px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ffd700, var(--tg-accent), #ffd700);
    margin-bottom: 0.75rem;
    box-shadow: 0 0 16px color-mix(in srgb, #ffd700 35%, transparent);
  }

  .lulu-modal__avatar {
    width: 5rem;
    height: 5rem;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    border: 2px solid var(--tg-bubble);
  }

  .lulu-modal__name {
    position: relative;
    z-index: 1;
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--tg-text);
    letter-spacing: 0.02em;
  }

  .lulu-modal__divider {
    position: relative;
    z-index: 1;
    width: 2.5rem;
    height: 2px;
    margin: 0.75rem auto;
    border-radius: 1px;
    background: linear-gradient(90deg, transparent, var(--tg-accent), transparent);
  }

  .lulu-modal__quote {
    position: relative;
    z-index: 1;
    margin: 0 0 1rem;
    font-size: 0.9rem;
    line-height: 1.65;
    font-style: italic;
    color: var(--tg-text-secondary);
    opacity: 0;
    transform: translateY(8px);
  }

  .lulu-modal.is-visible .lulu-modal__quote {
    animation: lulu-quote-in 0.45s ease 0.2s forwards;
  }

  .lulu-modal__redraw {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.4rem 1rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--tg-accent);
    background: color-mix(in srgb, var(--tg-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--tg-accent) 25%, transparent);
    border-radius: 9999px;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      transform 0.15s ease,
      box-shadow 0.2s ease;
  }

  .lulu-modal__redraw:hover {
    background: color-mix(in srgb, var(--tg-accent) 18%, transparent);
    box-shadow: 0 0 12px color-mix(in srgb, var(--tg-accent) 20%, transparent);
  }

  .lulu-modal__redraw:active {
    transform: scale(0.96);
  }

  .lulu-modal__card-flip.is-closing .lulu-modal__quote {
    animation: none;
    opacity: 0;
  }

  @property --lulu-glow-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  @keyframes lulu-card-enter {
    0% {
      transform: scale(0.88) rotateY(0deg);
      opacity: 0;
    }
    100% {
      transform: scale(1) rotateY(0deg);
      opacity: 1;
    }
  }

  @keyframes lulu-card-exit {
    0% {
      transform: scale(1) rotateY(0deg);
      opacity: 1;
    }
    100% {
      transform: scale(0.92) rotateY(0deg);
      opacity: 0;
    }
  }

  /* 扑克牌翻转：缩小 → 左右旋转（背面换语录）→ 恢复 */
  @keyframes lulu-card-flip {
    0% {
      transform: scale(1) rotateY(0deg);
    }
    12% {
      transform: scale(0.88) rotateY(0deg);
    }
    30% {
      transform: scale(0.78) rotateY(90deg);
    }
    50% {
      transform: scale(0.76) rotateY(180deg);
    }
    70% {
      transform: scale(0.78) rotateY(270deg);
    }
    88% {
      transform: scale(0.88) rotateY(360deg);
    }
    100% {
      transform: scale(1) rotateY(360deg);
    }
  }

  @keyframes lulu-card-tap {
    0% {
      transform: perspective(900px) rotateX(0deg) rotateY(0deg) scale(1) translateZ(0);
    }
    22% {
      transform: perspective(900px)
        rotateX(calc(var(--tap-y, 0) * -12deg))
        rotateY(calc(var(--tap-x, 0) * 12deg))
        scale(0.965)
        translateZ(-8px);
    }
    55% {
      transform: perspective(900px)
        rotateX(calc(var(--tap-y, 0) * 4deg))
        rotateY(calc(var(--tap-x, 0) * -4deg))
        scale(1.015)
        translateZ(3px);
    }
    100% {
      transform: perspective(900px) rotateX(0deg) rotateY(0deg) scale(1) translateZ(0);
    }
  }

  @keyframes lulu-edge-glow {
    0% {
      --lulu-glow-angle: 0deg;
      filter: brightness(1);
    }
    50% {
      --lulu-glow-angle: 180deg;
      filter: brightness(1.15);
    }
    100% {
      --lulu-glow-angle: 360deg;
      filter: brightness(1);
    }
  }

  @keyframes lulu-inner-glow {
    from {
      opacity: 0.5;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes lulu-quote-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lulu-modal__card-flip.is-entering {
      animation: lulu-card-fade-in 0.25s ease forwards;
    }

    .lulu-modal__card-flip.is-closing {
      animation: lulu-card-fade-out 0.2s ease forwards;
    }

    .lulu-modal__card-flip.is-redrawing {
      animation: lulu-card-fade-in 0.2s ease;
    }

    .lulu-modal__card.is-tapped {
      animation: none;
    }

    .lulu-modal__face--front::before {
      animation: none;
    }

    .lulu-modal__face--front::after {
      animation: none;
    }
  }

  @keyframes lulu-card-fade-in {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes lulu-card-fade-out {
    from {
      opacity: 1;
      transform: scale(1);
    }
    to {
      opacity: 0;
      transform: scale(0.95);
    }
  }
</style>
