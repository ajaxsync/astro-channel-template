---
import type { CollectionEntry } from 'astro:content';
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';
import { formatMessageTime } from '../utils/date';
import BubbleTail from './BubbleTail.astro';
import ChannelAvatar from './ChannelAvatar.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  Content: AstroComponentFactory;
  badge?: 'draft' | 'archived';
}

const { post, Content, badge } = Astro.props;
const { data, id } = post;

const slug = id.replace(/\.md$/, '');

const formattedTime = formatMessageTime(data.publishedAt);
---

<article class="group flex items-start gap-2 py-1" id={slug}>
  <div class="flex-shrink-0">
    <ChannelAvatar variant="trigger" />
  </div>

  <div class="flex-1 min-w-0 max-w-[calc(100%-3rem)]">
    <div class="tg-bubble-wrap">
      <BubbleTail />
      <div class="tg-bubble px-3 py-2">
      {data.image && (
        <div class="rounded-lg overflow-hidden -mx-1 mb-2">
          <img
            src={data.image}
            alt={data.title}
            class="w-full h-auto object-cover"
            loading="lazy"
          />
        </div>
      )}

      {data.title && (
        <p class="font-semibold text-[0.9375rem] leading-snug mb-1" style="color: var(--tg-text);">
          {badge && (
            <span
              class="inline-block text-[0.6875rem] font-medium px-1.5 py-0.5 rounded mr-1.5 align-middle"
              style="color: var(--tg-accent); background-color: color-mix(in srgb, var(--tg-accent) 12%, transparent);"
            >
              {badge === 'draft' ? '草稿' : '归档'}
            </span>
          )}
          {data.title}
        </p>
      )}

      <div class="prose">
        <Content />
      </div>

      {data.tags && data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1 mt-2">
          {data.tags.map((tag: string) => (
            <span class="text-xs" style="color: var(--tg-accent);">
              #{tag}
            </span>
          ))}
        </div>
      )}

      <div class="tg-meta">
        <a
          href={`/post/${slug}/`}
          class="opacity-0 group-hover:opacity-100 hover:!opacity-100 mr-1"
          style="color: var(--tg-accent);"
          aria-label="permalink"
          title="Permalink"
        >
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
        </a>
        <span>{formattedTime}</span>
      </div>
      </div>
    </div>
  </div>
</article>
