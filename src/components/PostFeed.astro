---
import PostCard from './PostCard.astro';
import { formatDateLabel } from '../utils/date';
import type { PostWithContent } from '../utils/posts';

interface Props {
  groupedPosts: Record<string, PostWithContent[]>;
  postsCount: number;
  emptyMessage: string;
  badge?: 'draft' | 'archived';
}

const { groupedPosts, postsCount, emptyMessage, badge } = Astro.props;
---

<div id="messages-container">
  {
    Object.entries(groupedPosts).map(([dateKey, dayPosts]) => (
      <div>
        <div class="flex justify-center py-3">
          <span class="tg-date-divider">{formatDateLabel(dateKey)}</span>
        </div>

        {dayPosts.map(({ post, Content }) => (
          <PostCard post={post} Content={Content} badge={badge} />
        ))}
      </div>
    ))
  }

  {
    postsCount === 0 && (
      <div class="text-center py-12">
        <svg
          class="w-16 h-16 mx-auto mb-4 opacity-30"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          style="color: var(--tg-text-secondary);"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
          />
        </svg>
        <p style="color: var(--tg-text-secondary);">{emptyMessage}</p>
      </div>
    )
  }
</div>
