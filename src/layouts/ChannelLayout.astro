---
import "../styles/global.css";
import ChannelAvatar from "../components/ChannelAvatar.astro";
import LuluCardModal from "../components/LuluCardModal.astro";
import { channelConfig } from "../config/channel";
import { getArchivedPosts, getDraftPosts } from "../utils/posts";
import { withBase } from "../utils/url";

interface Props {
  pageTitle: string;
}

const { pageTitle } = Astro.props;
const { name: channelName, tagline, githubUrl, faviconUrl } = channelConfig;

const [archivedPosts, draftPosts] = await Promise.all([
  getArchivedPosts(),
  getDraftPosts(),
]);
const hasArchive = archivedPosts.length > 0;
const hasDrafts = draftPosts.length > 0;
const bgImageUrl = withBase('/bgm.png');
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageTitle} />
    <link rel="icon" type="image/png" href={faviconUrl} />
    <title>{pageTitle} | {channelName}</title>
    <script is:inline>
      if (
        localStorage.theme === "dark" ||
        (!("theme" in localStorage) &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>
    <style is:inline set:html={`:root { --tg-bg-image: url("${bgImageUrl}"); }`}></style>
  </head>
  <body
    class="min-h-screen h-screen transition-colors duration-200"
    style="background-color: var(--tg-bg);"
  >
    <main
      class="h-full overflow-y-auto w-full tg-chat-bg"
      id="main-scroll-container"
    >
      <header id="channel-header" class="channel-header sticky top-0 z-40 w-full">
        <div class="channel-inner py-2.5">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3 min-w-0">
            <ChannelAvatar variant="home" />
            <div class="min-w-0">
              <h1
                class="text-base font-semibold truncate"
                style="color: var(--tg-text);"
              >
                {channelName}
              </h1>
              <p
                class="text-xs truncate"
                style="color: var(--tg-text-secondary);"
              >
                {tagline}
              </p>
            </div>
          </div>
          <div class="flex items-center gap-1 flex-shrink-0">
            {hasArchive && (
              <a
                href={withBase('/archive/')}
                class="p-2 rounded-full transition-opacity hover:opacity-70"
                aria-label="归档"
                style="color: var(--tg-text-secondary);"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"
                  />
                </svg>
              </a>
            )}
            {hasDrafts && (
              <a
                href={withBase('/drafts/')}
                class="p-2 rounded-full transition-opacity hover:opacity-70"
                aria-label="草稿"
                style="color: var(--tg-text-secondary);"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                  />
                </svg>
              </a>
            )}
            <a
              href={githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="p-2 rounded-full transition-opacity hover:opacity-70"
              aria-label="在 GitHub 上查看"
              style="color: var(--tg-text-secondary);"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
                ></path>
              </svg>
            </a>
            <button
              id="theme-toggle"
              class="bg-transparent border-none cursor-pointer hover:opacity-70 transition-opacity p-2"
              aria-label="切换主题"
              type="button"
              style="color: var(--tg-text-secondary);"
            >
              <svg
                class="w-5 h-5 dark:hidden"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
                ></path>
              </svg>
              <svg
                class="w-5 h-5 hidden dark:block"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
                ></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
      </header>

      <div class="channel-inner py-2">
        <slot />
      </div>
    </main>

    <LuluCardModal />

    <script>
      document.getElementById("theme-toggle")?.addEventListener("click", () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      });
    </script>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const scrollContainer = document.getElementById("main-scroll-container");
        const header = document.getElementById("channel-header");
        if (!scrollContainer || !header) return;

        const updateHeaderGlass = () => {
          const hasContentBelow = scrollContainer.scrollTop > 4;
          header.classList.toggle("is-scrolled", hasContentBelow);
        };

        scrollContainer.addEventListener("scroll", updateHeaderGlass, { passive: true });
        updateHeaderGlass();
      });
    </script>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const preElements = document.querySelectorAll("pre");
        const languageNames: Record<string, string> = {
          javascript: "JavaScript",
          js: "JavaScript",
          typescript: "TypeScript",
          ts: "TypeScript",
          python: "Python",
          py: "Python",
          bash: "Bash",
          shell: "Shell",
          json: "JSON",
          css: "CSS",
          html: "HTML",
          markup: "HTML",
          markdown: "Markdown",
          md: "Markdown",
          sql: "SQL",
          go: "Go",
          rust: "Rust",
          java: "Java",
          kotlin: "Kotlin",
          swift: "Swift",
          php: "PHP",
          ruby: "Ruby",
          csharp: "C#",
          cpp: "C++",
          "c++": "C++",
          c: "C",
          yaml: "YAML",
          yml: "YAML",
          xml: "XML",
          http: "HTTP",
          astro: "Astro",
          vue: "Vue",
          react: "React",
          svelte: "Svelte",
          solid: "Solid",
          lit: "Lit",
        };

        preElements.forEach((pre) => {
          const parent = pre.parentNode as HTMLElement | null;
          if (parent?.classList.contains("code-block-wrapper")) {
            return;
          }

          let language = "text";
          for (const className of pre.classList) {
            if (className.startsWith("language-")) {
              language = className.replace("language-", "");
              break;
            }
          }

          if (language === "text") {
            const code = pre.querySelector("code");
            if (code) {
              for (const className of code.classList) {
                if (className.startsWith("language-")) {
                  language = className.replace("language-", "");
                  break;
                }
              }
            }
          }

          const displayName =
            languageNames[language] ||
            language.charAt(0).toUpperCase() + language.slice(1);

          const code = pre.querySelector("code");
          if (!code) return;

          const wrapper = document.createElement("div");
          wrapper.className = "code-block-wrapper";

          const header = document.createElement("div");
          header.className = "code-block-header";

          const langSpan = document.createElement("span");
          langSpan.className = "code-block-lang";
          langSpan.textContent = displayName;

          const copyBtn = document.createElement("button");
          copyBtn.className = "code-block-copy";
          copyBtn.setAttribute("aria-label", "复制代码");

          copyBtn.innerHTML = `
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <span>复制</span>
          `;

          copyBtn.addEventListener("click", () => {
            const text = code.textContent;
            navigator.clipboard.writeText(text ?? "").then(() => {
              copyBtn.classList.add("copied");
              copyBtn.innerHTML = `
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>已复制</span>
              `;
              setTimeout(() => {
                copyBtn.classList.remove("copied");
                copyBtn.innerHTML = `
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                  <span>复制</span>
                `;
              }, 2000);
            });
          });

          header.appendChild(langSpan);
          header.appendChild(copyBtn);

          wrapper.appendChild(header);

          const parentEl = pre.parentNode;
          if (!parentEl) return;

          parentEl.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);
        });
      });
    </script>
  </body>
</html>
